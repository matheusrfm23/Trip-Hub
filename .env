# ==============================================================================
# 1. CONFIGURAÇÕES CRÍTICAS (INFRAESTRUTURA)
# ==============================================================================

# Define a porta universal do sistema (Docker e Python devem falar a mesma língua)
# Isso garante que o Docker exponha a 8000 e o Flet escute na 8000.
PORT=8000

# Chave de criptografia de sessão do Flet.
# Em produção, isso deve ser uma string aleatória longa.
FLET_SECRET_KEY=dev_local_secret_key_change_me_in_prod
# SEGURANÇA DA APLICAÇÃO
MASTER_PIN=2308

# Força o Flet a rodar como servidor Web (navegador) e não como app nativo de janela
FLET_FORCE_WEB_VIEW=true
FLET_SERVER_PORT=8000

