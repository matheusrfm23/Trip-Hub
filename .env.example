# FILE: .env.example
# CHANGE LOG:
# - Criado template de variáveis de ambiente para evitar vazamento de segredos.
# - Removidos valores reais de FLET_SECRET_KEY e MASTER_PIN.

# Configurações de Rede
PORT=8000
FLET_SERVER_PORT=8000

# Segurança (OBRIGATÓRIO ALTERAR EM PRODUÇÃO)
# Uma string aleatória longa para assinar as sessões do Flet
FLET_SECRET_KEY=your_secret_key_here_min_32_chars

# PIN mestre para funções administrativas do TripHub
MASTER_PIN=0000

# Interface e Comportamento
# Se true, força o Flet a rodar no navegador
FLET_FORCE_WEB_VIEW=true
